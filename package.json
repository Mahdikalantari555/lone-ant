{
  "name": "lone-ant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lone Ant — a browser-first pixel-art game where you live as one ant in a living colony.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "phaser": "3.80.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.3.3",
    "puppeteer": "23.6.0",
    "typescript": "5.5.4",
    "vite": "5.4.10"
  }
}
